# Do not publish model/reanalysis/data-heavy files
*.nc
*.grib2
*.idx
*.tmp
*.log
*.npz

# Python/cache clutter
__pycache__/
.ipynb_checkpoints/

# Never publish local model/cache folders
model_cache/
era5_cache/

# Optional local scratch folders
scratch/
temp/

# Never publish credentials or tokens
API key.txt
api_key.txt
apikey.txt
token.txt
tokens.txt
*.key
*.pem
*.env
